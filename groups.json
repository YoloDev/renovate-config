{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "packageRules": [
    {
      "matchDatasources": ["npm"],
      "groupName": "unified packages",
      "matchPackageNames": [
        "unified",
        "/^unist-/",
        "/^hast-/",
        "/^rehype-/",
        "/^remark-/",
        "hastscript"
      ]
    },
    {
      "matchDatasources": ["npm"],
      "groupName": "octokit packages",
      "matchPackageNames": ["@octokit/*"]
    },
    {
      "matchDatasources": ["npm"],
      "groupName": "github actions packages",
      "matchPackageNames": ["@actions/*"]
    },
    {
      "matchDatasources": ["nuget"],
      "groupName": "FsCheck packages",
      "matchPackageNames": ["FsCheck", "FsCheck.Xunit"]
    },
    {
      "matchDatasources": ["crate"],
      "groupName": "tracing crates",
      "matchPackageNames": ["tracing", "tracing-subscriber"]
    },
    {
      "matchDatasources": ["crate"],
      "groupName": "opentelemetry crates",
      "matchPackageNames": [
        "opentelemetry",
        "opentelemetry-appender-log",
        "opentelemetry-appender-tracing",
        "opentelemetry-http",
        "opentelemetry-jaeger-propagator",
        "opentelemetry-otlp",
        "opentelemetry-prometheus",
        "opentelemetry-proto",
        "opentelemetry_sdk",
        "opentelemetry-semantic-conventions",
        "opentelemetry-stdout",
        "opentelemetry-zipkin"
      ]
    },
    {
      "matchDatasources": ["crate"],
      "groupName": "sea-orm crates",
      "matchPackageNames": ["sea-orm", "sea-orm-migration"]
    },
    {
      "matchDatasources": ["crate"],
      "groupName": "aws sdk crates",
      "matchPackageNames": ["aws-config", "/^aws-sdk-[a-z]+$/"]
    }
  ]
}
